@using PlateE_learning.Data
@inject CurrentUserService CurrentUserService
@implements IDisposable

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm top-navbar">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">PlateE-Learning</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">Accueil</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="/cours">Cours</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="/#apropos">À propos</NavLink>
                </li>
                @if (CurrentUserService.IsAuthenticated)
                {
                    @if (CurrentUserService.Role == "Admin")
                    {
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/dashboard">Tableau de bord</NavLink>
                        </li>
                    }
                    else if (CurrentUserService.Role == "Enseignant")
                    {
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/espace-enseignant">Mon espace</NavLink>
                        </li>
                    }
                    else if (CurrentUserService.Role == "Apprenant")
                    {
                        <li class="nav-item">
                            <NavLink class="nav-link" href="/mes-cours">Mes cours</NavLink>
                        </li>
                    }
                }
            </ul>

            <div class="d-flex align-items-center">
                @if (!CurrentUserService.IsAuthenticated)
                {
                    <NavLink class="btn btn-outline-primary me-2" href="/login">Se Connecter</NavLink>
                    <NavLink class="btn btn-primary" href="/inscription">S'inscrire</NavLink>
                }
                else
                {
                    <span class="me-3 text-muted">@CurrentUserService.Role</span>
                    <button class="btn btn-outline-danger" @onclick="Logout">Se déconnecter</button>
                }
            </div>
        </div>
    </div>
</nav>

@code {
    protected override void OnInitialized()
    {
        CurrentUserService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        CurrentUserService.OnChange -= StateHasChanged;
    }

    private void Logout()
    {
        CurrentUserService.Logout();
        StateHasChanged();
    }
}

