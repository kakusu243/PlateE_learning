@page "/register"
@inject AuthService AuthService

<PageTitle>Inscription</PageTitle>

<h1>Inscription</h1>

<EditForm Model="registerModel" OnValidSubmit="OnRegisterAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Nom complet</label>
        <InputText class="form-control" @bind-Value="registerModel.DisplayName" />
    </div>
    <div class="mb-3">
        <label class="form-label">Email</label>
        <InputText class="form-control" @bind-Value="registerModel.Email" />
    </div>
    <div class="mb-3">
        <label class="form-label">Mot de passe</label>
        <InputText class="form-control" type="password" @bind-Value="registerModel.Password" />
    </div>

    <button class="btn btn-success" type="submit">Créer un compte</button>
</EditForm>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info mt-3">@message</div>
}

@code {
    private RegisterModel registerModel = new();
    private string message = string.Empty;

    private async Task OnRegisterAsync()
    {
        var result = await AuthService.RegisterAsync(registerModel.DisplayName, registerModel.Email, registerModel.Password, Roles.Learner);
        if (!result.Succeeded)
        {
            message = result.ErrorMessage;
            return;
        }

        message = "Votre compte a été créé. Vous pouvez maintenant vous connecter.";
        registerModel = new RegisterModel();
    }

    private class RegisterModel
    {
        public string DisplayName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
