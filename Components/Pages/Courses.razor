@page "/courses"
@inject AppDbContext DbContext
@inject NavigationManager NavigationManager

<PageTitle>Nos cours</PageTitle>

<h1>Catalogue des cours</h1>

@if (courses == null)
{
    <p><em>Chargement des cours...</em></p>
}
else if (!courses.Any())
{
    <div class="alert alert-info">Aucun cours disponible pour le moment.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var course in courses)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@course.Title</h5>
                        <p class="card-text">@course.Description</p>
                        <button class="btn btn-primary" @onclick="() => GoToCourse(course.Id)">Voir le cours</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Course>? courses;

    protected override async Task OnInitializedAsync()
    {
        courses = await DbContext.Courses
            .OrderByDescending(c => c.CreatedOn)
            .ToListAsync();
    }

    private void GoToCourse(int courseId)
    {
        NavigationManager.NavigateTo($"/courses/{courseId}");
    }
}
