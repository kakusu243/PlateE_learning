@page "/inscription"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using PlateE_learning.Models
@using PlateE_learning.Data
@inject IDbContextFactory<AppDbContext> DbFactory

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="card shadow-sm">
                <div class="card-body p-4 d-flex flex-column flex-lg-row align-items-stretch gap-4">
                    <div class="login-form flex-fill">
                        <h4 class="card-title mb-3">S'inscrire</h4>

                        @if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <div class="alert alert-danger mb-3">@ErrorMessage</div>
                        }

                        @if (!string.IsNullOrEmpty(SuccessMessage))
                        {
                            <div class="alert alert-success mb-3">@SuccessMessage</div>
                        }

                        <EditForm Model="@registerModel" OnValidSubmit="HandleInscription" OnInvalidSubmit="HandleInvalidSubmit">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="text-danger mb-3" />

                            <div class="mb-3">
                                <label class="form-label">Nom :</label>
                                <InputText @bind-Value="registerModel.Nom" class="form-control" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Prénom :</label>
                                <InputText @bind-Value="registerModel.Prenom" class="form-control" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Adresse mail :</label>
                                <InputText @bind-Value="registerModel.Email" type="email" class="form-control" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Rôle :</label>
                                <InputSelect @bind-Value="registerModel.Role" class="form-select">
                                    <option value="Apprenant">Apprenant</option>
                                    <option value="Enseignant">Enseignant</option>
                                </InputSelect>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Mot de passe :</label>
                                <InputText @bind-Value="registerModel.Password" type="password" class="form-control" />
                            </div>

                            <div class="form-check mb-3">
                                <InputCheckbox @bind-Value="registerModel.ReceiveInfo" class="form-check-input" id="receiveInfo" />
                                <label class="form-check-label" for="receiveInfo">Je veux recevoir les informations du système dans ma boîte mail</label>
                            </div>

                            <div class="form-check mb-4">
                                <InputCheckbox @bind-Value="registerModel.AcceptTerms" class="form-check-input" id="acceptTerms" />
                                <label class="form-check-label" for="acceptTerms">J'ai lu et j'accepte les conditions d'utilisation de ce site</label>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-cta">S'inscrire</button>
                            </div>
                        </EditForm>

                        <div class="mt-3 text-center">
                            <small>Déjà inscrit ? <a href="/login">Se connecter</a></small>
                        </div>
                    </div>
                    <div class="login-image-wrapper d-none d-lg-flex align-items-center justify-content-center">
                        <img src="images/Login_image.jpg" alt="inscription_image" class="login-image" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterModel registerModel = new RegisterModel();
    private string SuccessMessage = string.Empty;
    private string ErrorMessage = string.Empty;

    protected override void OnInitialized()
    {
        registerModel.Role = "Apprenant";
    }

    private async Task HandleInscription()
    {
        ErrorMessage = string.Empty;
        SuccessMessage = string.Empty;

        try
        {
            using var context = DbFactory.CreateDbContext();

            // 1. Vérification e-mail unique
            var emailExiste = await context.Utilisateurs.AnyAsync(u => u.Email == registerModel.Email);
            if (emailExiste)
            {
                ErrorMessage = "Cette adresse e-mail est déjà utilisée.";
                return;
            }

            // 2. Instanciation dynamique selon le rôle
            Utilisateur nouvelUtilisateur;
            if (registerModel.Role == "Enseignant")
            {
                nouvelUtilisateur = new Enseignant();
            }
            else
            {
                nouvelUtilisateur = new Apprenant();
            }

            // 3. Attribution des valeurs
            nouvelUtilisateur.NomComplet = $"{registerModel.Nom} {registerModel.Prenom}".Trim();
            nouvelUtilisateur.Email = registerModel.Email;
            nouvelUtilisateur.Role = registerModel.Role;
            nouvelUtilisateur.MotDePasse = registerModel.Password;
            nouvelUtilisateur.DateInscription = DateTime.Now;

            // 4. Enregistrement
            context.Utilisateurs.Add(nouvelUtilisateur);
            await context.SaveChangesAsync();

            SuccessMessage = "Inscription réussie ! Vous pouvez maintenant vous connecter.";
            registerModel = new RegisterModel(); // Réinitialisation du formulaire
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Erreur technique lors de l'enregistrement : {ex.Message}";
        }
    }

    private void HandleInvalidSubmit()
    {
        SuccessMessage = string.Empty;
        ErrorMessage = "Veuillez remplir correctement tous les champs requis et accepter les conditions d'utilisation.";
    }

    private class RegisterModel
    {
        [Required(ErrorMessage = "Le nom est requis")]
        public string Nom { get; set; } = string.Empty;

        [Required(ErrorMessage = "Le prénom est requis")]
        public string Prenom { get; set; } = string.Empty;

        [Required(ErrorMessage = "L'adresse mail est requise")]
        [EmailAddress(ErrorMessage = "Adresse mail invalide")]
        public string Email { get; set; } = string.Empty;

        [Required]
        public string Role { get; set; } = "Apprenant";

        [Required(ErrorMessage = "Le mot de passe est requis")]
        public string Password { get; set; } = string.Empty;

        public bool ReceiveInfo { get; set; }

        [Range(typeof(bool), "true", "true", ErrorMessage = "Vous devez accepter les conditions d'utilisation")]
        public bool AcceptTerms { get; set; }
    }
}