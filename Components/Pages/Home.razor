@page "/"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using PlateE_learning.Models
@using PlateE_learning.Data
@inject IDbContextFactory<AppDbContext> DbFactory

<!-- Section Hero -->
<section class="hero-section text-white py-5" id="home" style="background: linear-gradient(135deg, #0d6efd, #0a58ca); width: 100%;">
    <div class="container py-5">
        <div class="row align-items-center gy-4">
            <div class="col-lg-6">
                <span class="text-uppercase fw-bold text-white-50 small tracking-wider">PlateE-Learning</span>
                <h1 class="display-4 fw-bold mt-2 mb-3">Formez-vous. Certifiez-vous, Réussissez.</h1>
                <p class="lead mb-4">Apprenez à votre rythme et obtenez des certifications reconnues pour booster votre carrière.</p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="/inscription" class="btn btn-warning btn-lg fw-bold px-4 py-3 shadow-sm">Commencer un cours</a>
                    <a href="#cours" class="btn btn-outline-light btn-lg px-4 py-3">Voir les cours</a>
                </div>
            </div>
            <!-- 🌍 Image d'étudiantes africaines dynamiques et connectées -->
            <div class="col-lg-6 text-center">
                <img src="https://images.unsplash.com/photo-1531482615713-2afd69097998?auto=format&fit=crop&q=80&w=800"
                     class="img-fluid rounded-4 shadow-lg border border-light border-3"
                     alt="Étudiantes africaines qui étudient sur un ordinateur"
                     style="max-height: 400px; object-fit: cover; width: 100%;" />
            </div>
        </div>
    </div>
</section>

<!-- Section Cours Populaires (Dynamique depuis MySQL !) -->
<section class="courses-section py-5" id="cours">
    <div class="container">
        <div class="section-header text-center mb-5">
            <h2 class="fw-bold text-dark">Nos Dernières Formations</h2>
            <p class="text-muted">Découvrez les 3 cours les plus récents ajoutés sur notre plateforme.</p>
        </div>

        <div class="row g-4">
            @if (ListCours == null)
            {
                <div class="text-center py-5 w-100">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Chargement des cours...</span>
                    </div>
                </div>
            }
            else if (!ListCours.Any())
            {
                <div class="text-center py-5 w-100">
                    <p class="text-muted fs-5">Aucun cours n'est disponible dans la base de données pour le moment.</p>
                </div>
            }
            else
            {
                @foreach (var cours in ListCours)
                {
                    <div class="col-md-4">
                        <div class="course-card shadow-sm rounded-4 overflow-hidden h-100 d-flex flex-column bg-white border">
                            <img src="@(string.IsNullOrEmpty(cours.ImageUri) ? "images/devweb.jpg" : cours.ImageUri)"
                                 class="card-img-top"
                                 alt="@cours.Titre"
                                 style="height: 220px; object-fit: cover;" />
                            <div class="card-body d-flex flex-column justify-content-between flex-grow-1 p-4">
                                <div>
                                    <span class="badge bg-primary-subtle text-primary mb-2 px-3 py-2 rounded-pill">@cours.Niveau</span>
                                    <h5 class="card-title fw-bold text-dark mb-2">@cours.Titre</h5>
                                    <p class="card-text text-muted mb-3" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                        @cours.DescriptionCourte
                                    </p>
                                </div>
                                <div class="d-flex align-items-center justify-content-between mt-3 pt-3 border-top">
                                    <div>
                                        <span class="rating fw-bold text-warning">★ 4.8</span>
                                        <span class="text-muted small">(@cours.NombreInscrits apprenants)</span>
                                    </div>
                                    <a href="/login" class="btn btn-outline-primary btn-sm px-3 rounded-pill">Voir</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- Section À propos -->
<section class="about-section py-5 bg-white" id="apropos">
    <div class="container">
        <div class="row align-items-center gy-4">
            <div class="col-lg-6">
                <h2 class="fw-bold">La meilleure façon d'apprendre en ligne</h2>
                <p class="text-muted mb-4">Des parcours complets, des mentors expérimentés et des certifications pour booster votre carrière.</p>
                <ul class="list-unstyled text-muted lh-lg">
                    <li class="mb-2"><span class="text-primary fw-bold">✔</span> Cours élaborés par des experts</li>
                    <li class="mb-2"><span class="text-primary fw-bold">✔</span> Accès à vie et suivi personnalisé</li>
                    <li><span class="text-primary fw-bold">✔</span> Certificats reconnus à la fin de chaque parcours</li>
                </ul>
            </div>
            <div class="col-lg-6">
                <div class="p-4 shadow-sm rounded-4 bg-light border-start border-primary border-4">
                    <h5 class="fw-bold mb-3 text-primary">Découvrez un apprentissage flexible</h5>
                    <p class="text-muted mb-0">Passez de débutant à expert avec des ressources interactives, des cas pratiques et un accompagnement adapté à vos besoins quotidiens.</p>
                </div>
            </div>
        </div>
    </div>
</section>

