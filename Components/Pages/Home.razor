<!-- Section Appel à l'action -->
<section class="cta-section py-5 bg-white">
    <div class="container text-center">
        <div class="rounded-4 p-5 shadow-sm text-white" style="background: linear-gradient(135deg, #0d6efd, #0a58ca);">
            <h2 class="fw-bold mb-3">Rejoignez-nous dès aujourd'hui !</h2>
            <p class="mb-4 text-white-50">Inscrivez-vous et commencez votre parcours d'apprentissage dès maintenant.</p>
            <a href="/inscription" class="btn btn-light btn-lg me-3 text-primary fw-bold px-4 py-2">S'inscrire</a>
            <a href="/login" class="btn btn-outline-light btn-lg px-4 py-2">Se Connecter</a>
        </div>
    </div>
</section>

@code {
    private List<CoursDto>? ListCours;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var context = DbFactory.CreateDbContext();

            ListCours = await context.Cours
                .OrderByDescending(c => c.Id)
                .Take(3)
                .Select(c => new CoursDto
                {
                    Titre = c.Titre,
                    DescriptionCourte = c.Description,
                    ImageUri = c.MiniatureUrl,
                    NombreInscrits = 150
                })
                .ToListAsync();
        }
        catch (Exception)
        {
            ListCours = GetFallbackCourses();
        }
    }

    private List<CoursDto> GetFallbackCourses()
    {
        return new List<CoursDto>
        {
            new CoursDto { Titre = "Développement Web", DescriptionCourte = "Apprenez le HTML, CSS, JS et .NET pour concevoir des sites web modernes.", ImageUri = "images/devweb.jpg", Niveau = "Populaire", NombreInscrits = 320 },
            new CoursDto { Titre = "Marketing Digital", DescriptionCourte = "Maîtrisez le SEO, la publicité payante et la gestion de vos réseaux sociaux.", ImageUri = "images/marketing.jpg", Niveau = "Recommandé", NombreInscrits = 215 },
            new CoursDto { Titre = "Gestion de Projet", DescriptionCourte = "Adoptez les méthodologies agiles Scrum et Kanban pour piloter vos projets.", ImageUri = "images/projet.jpg", Niveau = "Nouveau", NombreInscrits = 98 }
        };
    }

    public class CoursDto
    {
        public string Titre { get; set; } = string.Empty;
        public string DescriptionCourte { get; set; } = string.Empty;
        public string ImageUri { get; set; } = string.Empty;
        public string Niveau { get; set; } = "Débutant";
        public int NombreInscrits { get; set; }
    }
}